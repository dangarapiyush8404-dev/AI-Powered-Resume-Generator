def predict_domain(skills):
    skills = skills.lower()

    if "python" in skills or "ml" in skills or "ai" in skills:
        return "Artificial Intelligence"
    if "react" in skills or "frontend" in skills:
        return "Web Development"
    if "sql" in skills or "database" in skills:
        return "Database Management"
    if "network" in skills:
        return "Networking"

    return "General"